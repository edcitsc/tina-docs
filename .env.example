# =============================================================================
# TinaCMS Self-Hosting Configuration
# =============================================================================
# Copy this file to .env.local and fill in values.

# --- Mode Toggles ---
# Set to "false" to enable remote DB + ADO git provider (production mode).
# Set to "true" (default) for local development with in-memory DB.
TINA_PUBLIC_USE_LOCAL_AUTH=true
TINA_PUBLIC_USE_LOCAL_DB=true

# --- Branch ---
NEXT_PUBLIC_TINA_BRANCH=main

# --- Authentication (Entra ID / Azure AD) ---
# Required when TINA_PUBLIC_USE_LOCAL_AUTH=false
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
NEXTAUTH_SECRET=           # Generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Comma-separated list of email addresses allowed to sign in.
TINA_ADMIN_EMAILS=user@example.com

# --- Database (Cosmos DB for MongoDB) ---
# Required when TINA_PUBLIC_USE_LOCAL_DB=false
MONGODB_URI=
MONGODB_DB=tinacms

# --- Git Provider (Azure DevOps Repos) ---
# Required when TINA_PUBLIC_USE_LOCAL_DB=false
ADO_ORG_URL=https://dev.azure.com/YourOrg
ADO_PROJECT=YourProject
ADO_REPO_ID=your-repo-guid
ADO_PAT=
ADO_BRANCH=main
ADO_COMMIT_AUTHOR_NAME=TinaCMS
ADO_COMMIT_AUTHOR_EMAIL=tinacms@localhost

# --- Media Storage (Azure Blob Storage) ---
# Required when TINA_PUBLIC_USE_LOCAL_AUTH=false (media API needs these)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_NAME=media
NEXT_PUBLIC_AZURE_STORAGE_PUBLIC_BASE_URL=https://youraccount.blob.core.windows.net/media

# --- Sitemap ---
NEXT_PUBLIC_SITE_URL=

# --- Theme ---
NEXT_PUBLIC_ENABLE_THEME_SELECTION=

# --- Analytics ---
NEXT_PUBLIC_GTM_ID=

# --- GitHub Metadata (optional: for last-edited date/author) ---
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_OWNER=