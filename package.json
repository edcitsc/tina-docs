{
  "name": "tina-docs",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "predev": "node scripts/check-pagefind.js",
    "dev": "tinacms dev -c \"next dev --turbopack\"",
    "build": "echo 'Starting TinaCMS build...' && tinacms build --skip-indexing --no-client-build-cache && echo 'TinaCMS build completed. Starting Next.js build...' && next build",
    "postbuild": "npx pagefind --site .next --output-path .next/static/pagefind && next-sitemap",
    "build-local-pagefind": "cross-env TINA_LOCAL_URL=http://localhost:4001/graphql NODE_ENV=production tinacms build --local --skip-indexing --no-client-build-cache -c \"npx next build && npx pagefind --site .next --output-subdir ../public/pagefind\"",
    "build:docker": "node scripts/docker-build.js",
    "export": "tinacms build --skip-indexing --no-client-build-cache && EXPORT_MODE=static,UNOPTIMIZED_IMAGES=true next build",
    "start": "tinacms build --skip-indexing --no-client-build-cache && next start",
    "build:index": "node scripts/build-index.js",
    "sync-content": "node scripts/sync-content.js",
    "lint": "biome check src/ tina/",
    "lint:fix": "biome check src/ tina/ --fix",
    "cleanup": "node scripts/cleanup.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.32.0",
    "@heroicons/react": "^2.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@next/third-parties": "^16.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-tabs": "^1.1.12",
    "@tinacms/datalayer": "^2.0.23",
    "copy-to-clipboard": "^3.3.3",
    "date-fns": "^4.1.0",
    "fast-glob": "^3.3.3",
    "formidable": "^3.5.4",
    "html-to-md": "^0.8.8",
    "lodash": "^4.17.21",
    "mermaid": "^11.6.0",
    "minisearch": "^7.2.0",
    "monaco-editor": "^0.52.2",
    "mongodb-level": "^0.0.4",
    "motion": "^12.15.0",
    "next": "^15.4.10",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "prism-react-renderer": "^2.4.1",
    "prismjs": "^1.30.0",
    "react": "^19.2.3",
    "react-animate-height": "^3.2.3",
    "react-dom": "^19.2.3",
    "react-dropzone": "^14.3.8",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "rehype-pretty-code": "^0.14.1",
    "shiki": "^3.6.0",
    "tinacms": "^3.9.1",
    "tinacms-authjs": "^23.0.1",
    "title-case": "^4.3.2",
    "typescript": "5.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.54.2",
    "@shikijs/transformers": "^3.6.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.1.8",
    "@tinacms/cli": "^2.4.4",
    "@types/formidable": "^3.5.1",
    "@types/node": "^24.2.1",
    "@types/react": "19.2.17",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "monaco-editor-webpack-plugin": "^7.1.0",
    "next-sitemap": "^4.2.3",
    "pagefind": "^1.3.0",
    "postcss": "^8.5.4",
    "postcss-preset-env": "^10.2.0",
    "tailwindcss": "^4.1.8",
    "worker-loader": "^3.0.8"
  },
  "pnpm": {
    "patchedDependencies": {
      "mongodb-level@0.0.4": "patches/mongodb-level.patch"
    }
  },
  "packageManager": "pnpm@9.15.2"
}
